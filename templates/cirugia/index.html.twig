{% extends 'base.html.twig' %}

{% block title %}Cirugia{% endblock %}

{% block titlewrap %}
    Cirugia
{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">Cirugia</li>
{% endblock %}

{% block body %}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                <i class="bi bi-info-circle-fill me-2"></i> {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}
    <div class="card card-primary card-outline mb-4">
        <div class="card-header">
            <h3 class="card-title">Cirugias Registradas</h3>
        </div>

        <div class="card-body">
            <table class="table table-striped dtHere">
                <thead>
                <tr>
                    <th>Paciente</th>
                    <th>Procedimiento</th>
                    <th>Quirofano</th>
                    <th>Fecha</th>
                    <th>Acciones</th>
                </tr>
                </thead>
                <tbody>
                {% for entity in entities %}
                    <tr class="align-middle">
                        <td>{{ entity.paciente.nombre }}</td>
                        <td>{{ entity.procedimientoPropuesto }}</td>
                        <td>{{ entity.quirofano.nombre }}</td>
                        <td>{{ entity.fechaPrograma|date('d/m/Y H:i') }}</td>
                        <td>
                            <a class="btn btn-secondary" href="{{ path('app_cirugia_show', {'id': entity.id}) }}">
                                <i class="bi bi-search"></i> Detalles
                            </a>
                            <a class="btn btn-success" href="{{ path('app_cirugia_edit', {'id': entity.id}) }}">
                                <i class="bi bi-pencil-square"></i> Editar
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="card-footer clearfix">
            <a href="{{ path('app_cirugia_new') }}" class="btn btn-primary btn-lg"><i class="bi bi-plus-circle-fill"></i> Nuevo</a>
        </div>

    </div>
{% endblock %}
