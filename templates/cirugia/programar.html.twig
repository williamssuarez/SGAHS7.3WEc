{% extends 'base.html.twig' %}

{% block title %}Programar Cirugía{% endblock %}

{% block body %}
    <div class="container-fluid px-4">
        <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
            <h2 class="text-dark fw-bold">
                <i class="bi bi-calendar-plus"></i> Programar Cirugía
            </h2>
            <a href="{{ path('app_cirugia_agenda') }}" class="btn btn-outline-secondary shadow-sm">
                <i class="bi bi-arrow-left"></i> Volver a la Agenda
            </a>
        </div>

        <div class="card shadow-sm border-top border-primary border-4">
            <div class="card-body bg-light">
                {{ form_start(form, {
                    'attr': {
                        'data-controller': 'submit-once',
                        'data-action': 'submit->submit-once#disable'
                    }
                }) }}
                {{ include('base/_form_error_messages.html.twig') }}

                <div class="row">
                    {# Left Column: Clinical Info #}
                    <div class="col-md-6 border-end">
                        <h5 class="text-primary border-bottom pb-2 mb-3">Datos del Paciente y Procedimiento</h5>

                        <div class="mb-3">
                            {{ form_row(form.paciente) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(form.diagnosticoPreoperatorio) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(form.procedimientoPropuesto) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(form.lateralidad) }}
                        </div>
                    </div>

                    {# Right Column: Logistics #}
                    <div class="col-md-6">
                        <h5 class="text-success border-bottom pb-2 mb-3">Logística y Recursos</h5>

                        <div class="mb-3">
                            {{ form_row(form.cirujanoPrincipal) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(form.fechaHoraProgramada) }}
                        </div>
                        <div class="mb-4">
                            <div class="alert alert-info py-2 mb-2 small">
                                <i class="bi bi-info-circle"></i> El quirófano puede asignarse ahora o el día de la cirugía.
                            </div>
                            {{ form_row(form.quirofano) }}
                        </div>

                        <div class="text-end mt-5">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm w-100" data-submit-once-target="submitButton">
                                <i class="bi bi-calendar-check-fill"></i>
                                {{ button_label|default('Confirmar y Programar') }}
                            </button>
                        </div>
                    </div>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
