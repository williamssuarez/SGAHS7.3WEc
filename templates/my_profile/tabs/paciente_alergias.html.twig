<h4>
    Alergias Registradas <a class="btn btn-primary btn-sm" href="{{ path('my_profile_alergias_new', {'uuid': app.user.externalProfile.uuid}) }}"><i class="bi bi-plus-circle"></i> Agregar</a>
</h4>
<table class="table table-striped dtHere">
    <thead>
    <tr>
        <th>#</th>
        <th>Alergeno</th>
        <th>Severidad</th>
        <th>Reacciones</th>
        <th>Observaciones</th>
        <th>Fecha</th>
        <th>Acciones</th>
    </tr>
    </thead>
    <tbody>
    {% for entity in alergias %}
        <tr class="align-middle">
            <td>{{ loop.index }}</td>
            <td>{{ entity.alergeno.nombre }}</td>
            <td>
                {% set badge = entity.alergiaSeveridadBadgeConfig %}
                <span class="badge rounded-pill {{ badge.class }}">
                    {{ badge.label }}
                </span>
            </td>
            <td>
                <ul>
                    {% for reaccion in entity.reacciones %}
                        <li>{{ reaccion.nombre }}</li>
                    {% endfor %}
                </ul>
            </td>
            <td>
                {{ entity.observaciones ? entity.observaciones : '--' }}
            </td>
            <td>
                {{ entity.created|date('d/m/Y H:i') }} <i>{{ entity.created|time_ago }}</i>
            </td>
            <td>
                {% if entity.uidCreate == app.user.id %}
                    <a class="btn btn-success" href="{{ path('my_profile_alergias_edit', {'id': entity.id, 'uuid': app.user.externalProfile.uuid}) }}">
                        <i class="bi bi-pencil-square"></i>
                    </a>
                {% endif %}
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
