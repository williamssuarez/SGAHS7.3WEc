<tr class="new-row" id="emergencia-{{ emergencia.id }}">
    <td>{{ emergencia.fechaIngreso|date('d/m/Y H:i A') }} ({{ emergencia.fechaIngreso|time_ago }})</td>
    <td>
        {% if emergencia.paciente %}
            <strong>{{ emergencia.paciente.nombre }} {{ emergencia.paciente.apellido }}</strong>
        {% else %}
            <strong class="text-danger"><i class="bi bi-incognito"></i> {{ emergencia.pacienteTemporal }}</strong>
            <button type="button"
                    class="btn btn-outline-primary"
                    data-controller="edit-patient"
                    data-edit-patient-url-value="{{ path('app_emergencia_edit_temporary_name', {id: emergencia.id}) }}"
                    data-action="click->edit-patient#editModal"
                    title="Editar nombre temporal">
                <i class="fa-solid fa-pen-to-square"></i>
            </button>
        {% endif %}
    </td>
    <td>{{ emergencia.triage.fechaEvaluacion|date('d/m/Y H:i A') }} ({{ emergencia.triage.fechaEvaluacion|time_ago }})</td>
    <td>
        {% set badge = emergencia.triage.triageNivelesPrioridadBadgeConfig %}
        <span class="badge {{ badge.class }} fs-6">
            {{ badge.label }}
        </span>
    </td>
    <td>
        <div class="btn-group" role="group">
            <button type="button"
                    class="btn btn-lg btn-info text-white"
                    data-controller="triage-details"
                    data-triage-details-url-value="{{ path('app_emergencia_triage_details', {id: emergencia.id}) }}"
                    data-action="click->triage-details#fetchAndShow"
                    title="Ver Triage">
                <i class="bi bi-clipboard2-pulse"></i>
            </button>

            <button type="button"
                    class="btn btn-lg btn-warning text-dark"
                    data-controller="assign-bed"
                    data-assign-bed-url-value="{{ path('app_emergencia_assign_bed', {id: emergencia.id}) }}"
                    data-action="click->assign-bed#openModal">
                Asignar Cama
            </button>

            {% if emergencia.paciente %}
                <button type="button"
                        class="btn btn-lg btn-outline-primary"
                        data-controller="assign-patient"
                        data-assign-patient-url-value="{{ path('app_emergencia_associate_patient', {id: emergencia.id}) }}"
                        data-action="click->assign-patient#openModal"
                        title="Vincular a perfil de paciente">
                    <i class="bi bi-person-lines-fill"></i> Cambiar Paciente
                </button>
                <button type="button"
                        class="btn btn-lg btn-outline-danger"
                        data-controller="unlink-patient"
                        data-unlink-patient-url-value="{{ path('app_emergencia_unlink_patient', {id: emergencia.id}) }}"
                        data-action="click->unlink-patient#unlink"
                        title="Desvincular paciente por error">
                    <i class="bi bi-person-x-fill"></i> Desvincular Paciente
                </button>
            {% else %}
                <button type="button"
                        class="btn btn-lg btn-outline-primary"
                        data-controller="assign-patient"
                        data-assign-patient-url-value="{{ path('app_emergencia_associate_patient', {id: emergencia.id}) }}"
                        data-action="click->assign-patient#openModal"
                        title="Vincular a perfil de paciente">
                    <i class="bi bi-person-lines-fill"></i> Identificar Paciente
                </button>
            {% endif %}
        </div>
    </td>
</tr>
