{% extends 'base.html.twig' %}

{% block title %}Nueva Alergia para {{ paciente.nombre|title }}{% endblock %}

{% block titlewrap %}
    Nueva Alergia para {{ paciente.nombre|title }}
{% endblock %}

{% block breadcrumb %}
