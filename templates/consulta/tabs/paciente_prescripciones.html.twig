<h4>
    Prescripciones Registradas <a class="btn btn-primary btn-sm" href="{{ path('app_prescripciones_new_consulta', {'id': consultum.id}) }}"><i class="bi bi-plus-circle"></i> Agregar</a>
</h4>
<table class="table table-striped dtHere">
    <thead>
    <tr>
        <th>#</th>
        <th>Medicicamento</th>
        <th>Dosis</th>
        <th>Frecuencia</th>
        <th>Estado</th>
        <th>Fecha Aparición</th>
        <th>Fecha Finalizada</th>
        <th>Observaciones</th>
        <th>Acciones</th>
    </tr>
    </thead>
    <tbody>
    {% for entity in paciente.prescripciones %}
        <tr class="align-middle">
            <td>{{ loop.index }}</td>
            <td>{{ entity.medicamento }}</td>
            <td>{{ entity.dosis }}</td>
            <td>{{ entity.frecuencia }}</td>
            <td>
                {% set badge = entity.prescripcionesEstadosBadgeConfig %}
                <span class="badge rounded-pill {{ badge.class }}">
                    {{ badge.label }}
                </span>
            </td>
            <td>{{ entity.fechaInicio|date('d/m/Y') }}</td>
            <td>{{ entity.fechaFin ? entity.fechaFin|date('d/m/Y') : ' ' }}</td>
            <td>
                {{ entity.observaciones ? entity.observaciones : '--' }}
            </td>
            <td>
                <a class="btn btn-success" href="{{ path('app_prescripciones_edit_consulta', {'id': entity.id}) }}">
                    <i class="bi bi-pencil-square"></i>
                </a>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
