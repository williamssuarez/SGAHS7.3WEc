<h4>
    Prescripciones Registradas
    {% if consultum.estadoConsulta.value == 'active' %}
        <a class="btn btn-primary btn-sm" href="{{ path('app_prescripciones_new_consulta', {'id': consultum.id}) }}"><i class="bi bi-plus-circle"></i> Agregar</a>
    {% endif %}
</h4>

<div class="card card-primary card-outline">
    <div class="card-header">
        <div class="card-title">Prescripciones Activas</div>
    </div>

    <div class="card-body">
        <table class="table table-striped dtHere">
            <thead>
            <tr>
                <th>#</th>
                <th>Medicicamento</th>
                <th>Dosis</th>
                <th>Frecuencia</th>
                <th>Estado</th>
                <th>Fecha Inicio</th>
                <th>Fecha Fin</th>
                <th>Observaciones</th>
                {% if consultum.estadoConsulta.value == 'active' %}
                    <th>Acciones</th>
                {% endif %}
            </tr>
            </thead>
            <tbody>
            {% for entity in prescripcionesActivas %}
                <tr class="align-middle">
                    <td>{{ loop.index }}</td>
                    <td>{{ entity.medicamento }}</td>
                    <td>{{ entity.dosis }}</td>
                    <td>{{ entity.frecuencia }}</td>
                    <td>
                        {% set badge = entity.prescripcionesEstadosBadgeConfig %}
                            <span class="badge rounded-pill {{ badge.class }}">
                                {{ badge.label }}
                            </span>
                    </td>
                    {#no dejar que twig traduzca del utc#}
                    <td>{{ entity.fechaInicio|date('d/m/Y', false) }}</td>
                    <td>{{ entity.fechaFin ? entity.fechaFin|date('d/m/Y', false) : ' ' }}</td>
                    <td>
                        {{ entity.observaciones ? entity.observaciones : '--' }}
                    </td>
                    {% if consultum.estadoConsulta.value == 'active' %}
                        <td>
                            <a class="btn btn-success" href="{{ path('app_prescripciones_edit_consulta', {'id': entity.id, 'consulta': consultum.id}) }}">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a class="btn btn-danger" target="_blank" href="{{ path('app_prescripciones_print_prescripcion', {'id': entity.id, 'consulta': consultum.id}) }}">
                                <i class="bi bi-file-earmark-pdf"></i>
                            </a>
                        </td>
                    {% endif %}
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<br>

