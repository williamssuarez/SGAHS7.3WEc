<h4>
    Discapacidades Registradas <a class="btn btn-primary btn-sm" href="{{ path('app_paciente_condiciones_new_consulta', {'id': consultum.id}) }}"><i class="bi bi-plus-circle"></i> Agregar</a>
</h4>
<table class="table table-striped dtHere">
    <thead>
    <tr>
        <th>Nombre</th>
        <th>Descripcion</th>
        <th>Acciones</th>
    </tr>
    </thead>
    <tbody>
    {% for entity in paciente.pacienteDiscapacidades %}
        <tr class="align-middle">
            <td>{{ entity.nombre }}</td>
            <td>{{ entity.descripcion }}</td>
            <td>
                <a class="btn btn-success" href="{{ path('app_discapacidades_edit', {'id': entity.id}) }}">
                    <i class="bi bi-pencil-square"></i> Editar
                </a>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
