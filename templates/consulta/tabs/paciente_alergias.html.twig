<h4>
    Alergias Registradas
    {% if consultum.estadoConsulta.value == 'active' %}
        <a class="btn btn-primary btn-sm" href="{{ path('app_alergias_new_consulta', {'id': consultum.id}) }}"><i class="bi bi-plus-circle"></i> Agregar</a>
    {% endif %}
</h4>
<table class="table table-striped dtHere">
    <thead>
    <tr>
        <th>#</th>
        <th>Alergeno</th>
        <th>Severidad</th>
        <th>Reacciones</th>
        <th>Observaciones</th>
        <th>Fecha</th>
        {% if consultum.estadoConsulta.value == 'active' %}
            <th>Acciones</th>
        {% endif %}
    </tr>
    </thead>
    <tbody>
    {% for entity in alergias %}
        <tr class="align-middle">
            <td>{{ loop.index }}</td>
            <td>{{ entity.alergeno.nombre }}</td>
            <td>
                {% set badge = entity.alergiaSeveridadBadgeConfig %}
                <span class="badge rounded-pill {{ badge.class }}">
                    {{ badge.label }}
                </span>
            </td>
            <td>
                <ul>
                    {% for reaccion in entity.reacciones %}
                        <li>{{ reaccion.nombre }}</li>
                    {% endfor %}
                </ul>
            </td>
            <td>
                {{ entity.observaciones ? entity.observaciones : '--' }}
            </td>
            <td>
                {{ entity.created|date('d/m/Y H:i') }} <i>{{ entity.created|time_ago }}</i>
            </td>
            {% if consultum.estadoConsulta.value == 'active' %}
                <td>
                    <a class="btn btn-success" href="{{ path('app_alergias_edit_consulta', {'id': entity.id, 'consulta': consultum.id}) }}">
                        <i class="bi bi-pencil-square"></i>
                    </a>
                </td>
            {% endif %}
        </tr>
    {% endfor %}
    </tbody>
</table>
