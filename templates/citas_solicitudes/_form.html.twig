{{ form_start(form, {
    'attr': {
        'data-controller': 'submit-once',
        'data-action': 'submit->submit-once#disable'
    }
}) }}
{{ include('base/_form_error_messages.html.twig') }}
<div class="card-body">
    <h5>Solicitar Cita:</h5>
    <div class="row">
        <div class="col-md-12">
            <div class="mb-3">
                {{form_label( form.especialidad ) }}
                <div class="input-group">
                    {{form_widget( form.especialidad ) }}
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="mb-3">
                {{form_label( form.motivoConsulta ) }}
                <div class="input-group">
                    {{form_widget( form.motivoConsulta ) }}
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card-footer">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between">
                <a class="btn btn-primary" href="{{ path('app_citas_solicitudes_index', {'id': entity.id}) }}">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>

                <div class="d-flex">
                    <button type="submit" class="btn btn-success" data-submit-once-target="submitButton">
                        {{ button_label|default('Guardar') }}
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
{{ form_end(form) }}
