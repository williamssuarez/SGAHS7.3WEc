{{ form_start(form, {
    'attr': {
        'data-controller': 'submit-once',
        'data-action': 'submit->submit-once#disable'
    }
}) }}
{{ include('base/_form_error_messages.html.twig') }}
<div class="card-body">
    <div class="mb-3">
        {{form_label( form.enfermedad ) }}
        {{form_widget( form.enfermedad ) }}
    </div>
    <div class="mb-3">
        {{form_label( form.fechaDiagnostico ) }}
        {{form_widget( form.fechaDiagnostico ) }}
    </div>
    <div class="mb-3">
        {{ form_label(form.tipo) }}
        <div class="row">
            <div class="col-sm-12">
                <div class="d-flex flex-wrap"> {# Use flex for easy alignment #}
                    {% for child in form.tipo %}
                        <div class="form-check form-check-inline me-3">
                            {{ form_widget(child) }}
                            {{ form_label(child) }}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
    <div class="mb-3">
        {{form_label( form.cronica ) }}
        {{form_widget( form.cronica ) }}
    </div>
    <div class="mb-3">
        {{form_label( form.notas ) }}
        {{form_widget( form.notas ) }}
    </div>
</div>

<div class="card-footer">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between">
                {#<a class="btn btn-primary" href="{{ path('app_paciente_show', {'id': paciente.id}) }}">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>#}

                <div class="d-flex">
                    <button type="submit" class="btn btn-success" data-submit-once-target="submitButton">
                        {{ button_label|default('Guardar') }}
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
{{ form_end(form) }}
