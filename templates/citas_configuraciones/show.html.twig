{% extends 'base.html.twig' %}

{% block title %}CitasConfiguraciones{% endblock %}

{% block body %}
    <h1>CitasConfiguraciones</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ citas_configuracione.id }}</td>
            </tr>
            <tr>
                <th>HoraInicio</th>
                <td>{{ citas_configuracione.horaInicio ? citas_configuracione.horaInicio|date('H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>HoraFin</th>
                <td>{{ citas_configuracione.horaFin ? citas_configuracione.horaFin|date('H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>MaxPacientesDia</th>
                <td>{{ citas_configuracione.maxPacientesDia }}</td>
            </tr>
            <tr>
