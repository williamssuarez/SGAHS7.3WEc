                <td>{{ citas_configuracione.uidCreate }}</td>
            </tr>
            <tr>
                <th>UidUpdate</th>
                <td>{{ citas_configuracione.uidUpdate }}</td>
            </tr>
            <tr>
                <th>Created</th>
                <td>{{ citas_configuracione.created ? citas_configuracione.created|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Updated</th>
                <td>{{ citas_configuracione.updated ? citas_configuracione.updated|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_citas_configuraciones_index') }}">back to list</a>

    <a href="{{ path('app_citas_configuraciones_edit', {'id': citas_configuracione.id}) }}">edit</a>

    {{ include('citas_configuraciones/_delete_form.html.twig') }}
{% endblock %}
