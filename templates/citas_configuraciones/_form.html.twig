{{ form_start(form, {
    'attr': {
        'data-controller': 'submit-once',
        'data-action': 'submit->submit-once#disable'
    }
}) }}
{{ include('base/_form_error_messages.html.twig') }}
<div class="card-body">
    <h5>Configurar Parametros de Cita:</h5>
    <div class="row">
        <div class="col-md-12">
            <div class="mb-3">
                {{form_label( form.especialidad ) }}
                <div class="input-group">
                    {{form_widget( form.especialidad ) }}
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="mb-3">
                {{form_label( form.consultorio ) }}
                <div class="input-group">
                    {{form_widget( form.consultorio ) }}
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="mb-3">
                {{form_label( form.horaInicio ) }}
                <div class="input-group">
                    {{form_widget( form.horaInicio ) }}
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="mb-3">
                {{form_label( form.horaFin ) }}
                <div class="input-group">
                    {{form_widget( form.horaFin ) }}
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="mb-3">
                {{form_label( form.maxPacientesDia ) }}
                <div class="input-group">
                    {{form_widget( form.maxPacientesDia ) }}
                </div>
            </div>
        </div>
    </div>

    <div class="row" data-controller="conditional-field">
        <div class="col-md-4">
            <div class="mb-3">
                {{form_label( form.duracionCita ) }}
                <div class="input-group">
                    {{form_widget( form.duracionCita ) }}
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="mb-3">
                {{form_label( form.tieneTiempoReceso ) }}
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                {{form_widget( form.tieneTiempoReceso ) }}
            </div>
        </div>
        <div class="col-md-4">
            <div data-conditional-field-target="container" class="d-none mb-3">
                <div class="mb-3">
                    {{form_label( form.tiempoReceso ) }}
                    <div class="input-group">
                        {{form_widget( form.tiempoReceso ) }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row" data-controller="conditional-field">
        <div class="col-md-4">
            <div class="mb-3">
                {{form_label( form.diasSemana ) }}
                <div class="input-group">
                    {{form_widget( form.diasSemana ) }}
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="mb-3">
                {{form_label( form.tieneEdadPrioridad ) }}
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                {{form_widget( form.tieneEdadPrioridad ) }}
            </div>
        </div>
        <div class="col-md-4">
            <div data-conditional-field-target="container" class="d-none mb-3">
                <div class="mb-3">
                    {{form_label( form.edadPrioridad ) }}
                    <div class="input-group">
                        {{form_widget( form.edadPrioridad ) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card-footer">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between">
                <a class="btn btn-primary" href="{{ path('app_citas_configuraciones_index', {'id': entity.id}) }}">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>

                <div class="d-flex">
                    <button type="submit" class="btn btn-success" data-submit-once-target="submitButton">
                        {{ button_label|default('Guardar') }}
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
{{ form_end(form) }}
