{% extends 'base.html.twig' %}

{% block title %}PacienteCondiciones{% endblock %}

{% block body %}
    <h1>PacienteCondiciones</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ paciente_condicione.id }}</td>
            </tr>
            <tr>
                <th>FechaAparicion</th>
                <td>{{ paciente_condicione.fechaAparicion ? paciente_condicione.fechaAparicion|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>FechaFinalizada</th>
                <td>{{ paciente_condicione.fechaFinalizada ? paciente_condicione.fechaFinalizada|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Estado</th>
                <td>{{ paciente_condicione.estado }}</td>
            </tr>
            <tr>
                <th>Observaciones</th>
                <td>{{ paciente_condicione.observaciones }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_paciente_condiciones_index') }}">back to list</a>

    <a href="{{ path('app_paciente_condiciones_edit', {'id': paciente_condicione.id}) }}">edit</a>

    {{ include('paciente_condiciones/_delete_form.html.twig') }}
{% endblock %}
