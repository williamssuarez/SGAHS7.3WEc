{{ form_start(form) }}
{{ include('base/_form_error_messages.html.twig') }}
<div class="card-body">
    <div class="mb-3">
        {{form_label( form.condicion ) }}
        {{form_widget( form.condicion ) }}
    </div>
    <div class="mb-3">
        {{form_label( form.fechaAparicion ) }}
        {{form_widget( form.fechaAparicion ) }}
    </div>
    {# Wrap the entire section in the controller #}
    <div data-controller="toggle-date" data-toggle-date-hidden-value-value="resolved">
        <div class="mb-3">
            {{ form_label(form.estado) }}
            <div class="row">
                <div class="col-sm-12">
                    <div class="d-flex flex-wrap">
                        {% for child in form.estado %}
                            <div class="form-check form-check-inline me-3">
                                {{ form_widget(child) }}
                                {{ form_label(child) }}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <div class="mb-3" data-toggle-date-target="endDateContainer">
            {{ form_label(form.fechaFinalizada) }}
            {{ form_widget(form.fechaFinalizada) }}
        </div>
    </div>
    <div class="mb-3">
        {{form_label( form.observaciones ) }}
        {{form_widget( form.observaciones ) }}
    </div>
</div>

<div class="card-footer">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between">
                {#<a class="btn btn-primary" href="{{ path('app_paciente_show', {'id': paciente.id}) }}">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>#}

                <div class="d-flex">
                    <button class="btn btn-success">
                        {{ button_label|default('Guardar') }}
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
{{ form_end(form) }}
