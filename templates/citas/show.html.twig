{% extends 'base.html.twig' %}

{% block title %}Citas{% endblock %}

{% block body %}
    <h1>Citas</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ cita.id }}</td>
            </tr>
            <tr>
                <th>Fecha</th>
                <td>{{ cita.fecha ? cita.fecha|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>HoraInicio</th>
                <td>{{ cita.horaInicio ? cita.horaInicio|date('H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>HoraFin</th>
                <td>{{ cita.horaFin ? cita.horaFin|date('H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UidCreate</th>
                <td>{{ cita.uidCreate }}</td>
            </tr>
            <tr>
                <th>UidUpdate</th>
                <td>{{ cita.uidUpdate }}</td>
            </tr>
            <tr>
                <th>Created</th>
                <td>{{ cita.created ? cita.created|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Updated</th>
                <td>{{ cita.updated ? cita.updated|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_citas_index') }}">back to list</a>

    <a href="{{ path('app_citas_edit', {'id': cita.id}) }}">edit</a>

    {{ include('citas/_delete_form.html.twig') }}
{% endblock %}
