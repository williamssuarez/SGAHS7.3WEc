{# templates/inventario_lote/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Historial de Lote - {{ lote.articulo.nombre }}{% endblock %}

{% block body %}
    <div class="container-fluid px-4">

        {# --- HEADER & ACTIONS --- #}
        <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
            <div>
                <h2 class="text-dark fw-bold mb-0">
                    <i class="bi bi-clock-history"></i> Historial de Lote
                </h2>
                <p class="text-muted mb-0">Auditoría de movimientos de inventario.</p>
            </div>
            <div class="d-flex gap-2">
                <a href="{{ path('app_inventario_lote_index') }}" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Inventario
                </a>
                <a href="{{ path('app_inventario_lote_ajuste', {'id': lote.id}) }}" class="btn btn-outline-warning text-dark shadow-sm" title="Ajuste Manual">
                    <i class="bi bi-sliders"></i> Ajustar
                </a>
                <button class="btn btn-outline-dark shadow-sm" onclick="window.print()">
                    <i class="bi bi-printer"></i> Imprimir Reporte
                </button>
            </div>
        </div>

        {# --- TOP SUMMARY DASHBOARD --- #}
        <div class="row g-4 mb-4">
            {# Card 1: Article Info #}
            <div class="col-md-4">
                <div class="card shadow-sm border-start border-primary border-4 h-100">
                    <div class="card-body">
                        <h6 class="text-muted mb-1">Artículo</h6>
                        <h4 class="fw-bold text-primary mb-0">{{ lote.articulo.nombre }}</h4>
                        <span class="badge bg-light text-dark border mt-2"><i class="bi bi-upc-scan"></i> {{ lote.lote }}</span>
                    </div>
                </div>
            </div>

            {# Card 2: Current Stock #}
            <div class="col-md-4">
                {% set isLowStock = lote.cantidadActual <= lote.articulo.stockMinimo %}
                <div class="card shadow-sm border-start {{ isLowStock ? 'border-warning' : 'border-success' }} border-4 h-100">
                    <div class="card-body">
                        <h6 class="text-muted mb-1">Existencia Actual</h6>
                        <h3 class="fw-bold {{ isLowStock ? 'text-warning' : 'text-success' }} mb-0">
                            {{ lote.cantidadActual }} <span class="fs-6 text-muted">{{ lote.articulo.unidadMedida }}</span>
                        </h3>
                        {% if isLowStock %}
                            <small class="text-danger fw-bold"><i class="bi bi-exclamation-triangle"></i> Por debajo del mínimo ({{ lote.articulo.stockMinimo }})</small>
                        {% else %}
                            <small class="text-success"><i class="bi bi-check-circle"></i> Stock Suficiente</small>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Card 3: Expiration #}
            <div class="col-md-4">
                {% set isExpired = date(lote.fechaCaducidad) < date('now') %}
                <div class="card shadow-sm border-start {{ isExpired ? 'border-danger' : 'border-info' }} border-4 h-100">
                    <div class="card-body">
                        <h6 class="text-muted mb-1">Fecha de Caducidad</h6>
                        <h4 class="fw-bold {{ isExpired ? 'text-danger' : 'text-dark' }} mb-0">
                            {{ lote.fechaCaducidad|date('d/m/Y') }}
                        </h4>
                        {% if isExpired %}
                            <span class="badge bg-danger mt-2">CADUCADO</span>
                        {% else %}
                            <small class="text-muted">Vence en {{ date('now').diff(date(lote.fechaCaducidad)).days }} días</small>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {# --- THE FORENSIC LEDGER (TABLE) --- #}
        <div class="card shadow-sm border-top border-dark border-4">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-list-columns-reverse"></i> Registro de Movimientos</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover dtHere align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Fecha y Hora</th>
                            <th>Tipo</th>
                            <th>Cantidad</th>
                            <th>Usuario Responsable</th>
                            <th>Referencia / Motivo</th>
                        </tr>
                        </thead>
                        <tbody>
                        {# Sort descending so the newest movement is at the top #}
                        {% for mov in lote.movimientoInventarios|sort((a, b) => b.created <=> a.created) %}

                            {# Visual logic based on the type of movement #}
                            {% set isEntrada = mov.tipoMovimiento.value == 'entrada' %}
                            {% set isAjuste = mov.tipoMovimiento.value == 'ajuste' %}
                            {% set isEdition = mov.tipoMovimiento.value == 'edicion' %}

                            <tr class="{{ isAjuste ? 'table-warning' : '' }}">
                                <td>
                                    {{ loop.index }}
                                </td>
                                <td class="fw-bold text-muted">
                                    {{ mov.created|date('d/m/Y') }} <br>
                                    <small>{{ mov.created|date('h:i A') }}</small>
                                </td>

                                <td>
                                    {% set badge = mov.tipoMovimientoBadgeConfig %}
                                    <span class="badge rounded-pill {{ badge.class }}">
                                        {{ badge.label }}
                                    </span>
                                </td>

                                {% if isEdition %}
                                    <td class="fs-5 fw-bold text-primary">
                                        {{ mov.cantidad|abs }}
                                    </td>
                                {% elseif isAjuste %}
                                    <td class="fs-5 fw-bold text-warning">
                                        <i class="bi bi-arrow-repeat"></i> {{ mov.cantidad|abs }}
                                    </td>
                                {% else %}
                                    <td class="fs-5 fw-bold {{ isEntrada ? 'text-success' : 'text-danger' }}">
                                        {{ isEntrada ? '+' : '-' }}{{ mov.cantidad|abs }}
                                    </td>
                                {% endif %}

                                <td>
                                    <i class="bi bi-person-badge text-primary"></i>
                                    {{ mov.uidCreate|public_username }}
                                </td>

                                <td>
                                    <span class="text-muted fst-italic">
                                        {{ mov.referenciaOrigen|default('Sin referencia especificada') }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
