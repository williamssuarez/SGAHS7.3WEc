{% extends 'base.html.twig' %}

{% block title %}Expediente - {{ entity.paciente.nombre }}{% endblock %}

{% block titlewrap %}
    Hospitalizaciones - Expediente
{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">Hospitalizaciones</li>
{% endblock %}

{% block body %}
    <div class="container-fluid px-0">

        {# 1. THE PATIENT HEADER: Permanent Identity & Location #}
        <div class="card shadow-sm mb-4 border-top border-primary border-3">
            <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                <div class="mb-3 mb-md-0">
                    <h2 class="mb-1 text-dark fw-bold">
                        {{ entity.paciente.nombre }} {{ entity.paciente.apellido }}
                        <a class="btn btn-outline-primary btn-sm" target="_blank" href="{{ path('app_paciente_show', { 'id': entity.paciente.id }) }}">
                            <i class="fa-solid fa-address-book"></i> Perfil Completo
                        </a>
                    </h2>
                    <div class="text-muted fs-6 mt-2">
                    <span class="me-3">
                        <i class="bi bi-geo-alt-fill text-primary"></i>
                        <strong>Ubicación:</strong>
                        {{ entity.camaActual.habitacion.area.nombre }} -
                        {{ entity.camaActual.habitacion.nombre }} (Cama {{ entity.camaActual.codigo }})
                    </span>
                        <span class="me-3">
                        <i class="bi bi-calendar-check text-warning"></i>
                        <strong>Ingreso:</strong> {{ entity.fechaIngreso|date('d/m/Y') }}
                        <span class="badge bg-light text-dark border">
                            Día {{ date('now').diff(entity.fechaIngreso).days + 1 }}
                        </span>
                    </span>
                        <span>
                        <i class="bi bi-person-badge text-info"></i>
                        <strong>Médico Tratante:</strong>
                        {{ entity.medicoTratante ? 'Dr(a). ' ~ entity.medicoTratante.user.nombre : 'No Asignado' }}
                    </span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <a href="{{ path('app_hospitalizacion_censo') }}" class="btn btn-secondary shadow-sm">
                        <i class="bi bi-arrow-left"></i> Volver al Censo
                    </a>

                    {# The Ultimate Goal: Discharging the patient #}
                    {% if is_granted('ROLE_DOCTOR') %}
                        <button type="button" class="btn btn-success shadow-sm" data-bs-toggle="modal" data-bs-target="#altaModal">
                            <i class="bi bi-box-arrow-right"></i> Dar de Alta Hospitalaria
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="row">
            {# 2. LEFT COLUMN: Context & Origin #}
            <div class="col-lg-3 mb-4">

                {# Context Card #}
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light py-2">
                        <h6 class="card-title mb-0 fw-bold"><i class="bi bi-info-circle text-primary"></i> Motivo de Ingreso</h6>
                    </div>
                    <div class="card-body">
                        <p class="mb-0">{{ entity.diagnosticoIngreso|nl2br }}</p>
                    </div>
                </div>

                {# Link back to ER if they came from there #}
                {% if entity.emergencia %}
                    <div class="card shadow-sm border-danger border-start border-4">
                        <div class="card-body">
                            <h6 class="fw-bold text-danger"><i class="bi bi-ambulance"></i> Origen: Emergencia</h6>
                            <p class="small text-muted mb-2">Ingresado desde Tópico el {{ entity.emergencia.fechaIngreso|date('d/m/Y') }}</p>
                            <a href="{{ path('app_emergencia_show_record', {'id': entity.emergencia.id}) }}" target="_blank" class="btn btn-outline-danger btn-sm w-100">
                                <i class="bi bi-file-earmark-medical"></i> Ver Expediente ER
                            </a>
                        </div>
                    </div>
                {% endif %}

            </div>

            {# 3. RIGHT COLUMN: The Clinical Tabs #}
            <div class="col-lg-9">
                <div class="card shadow-sm">
                    <div class="card-header bg-white p-0">
                        <ul class="nav nav-tabs nav-justified" id="inpatientTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active py-3 fw-bold" id="evoluciones-tab" data-bs-toggle="tab" data-bs-target="#evoluciones" type="button" role="tab" aria-controls="evoluciones" aria-selected="true">
                                    <i class="bi bi-journal-medical"></i> Evoluciones Médicas
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link py-3 fw-bold text-success" id="kardex-tab" data-bs-toggle="tab" data-bs-target="#kardex" type="button" role="tab" aria-controls="kardex" aria-selected="false">
                                    <i class="bi bi-card-checklist"></i> Indicaciones / Kardex
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link py-3 fw-bold text-danger" id="vitals-tab" data-bs-toggle="tab" data-bs-target="#vitals" type="button" role="tab" aria-controls="vitals" aria-selected="false">
                                    <i class="bi bi-heart-pulse"></i> Sábana de Signos Vitales
                                </button>
                            </li>
                        </ul>
                    </div>

                    <div class="card-body p-4">
                        <div class="tab-content" id="inpatientTabsContent">

                            {# TAB 1: EVOLUCIONES #}
                            {# --- THE MISSING WRAPPER WAS ADDED HERE --- #}
                            <div class="tab-pane fade show active" id="evoluciones" role="tabpanel" aria-labelledby="evoluciones-tab" tabindex="0">

                                {# --- THE NEW EVOLUTION FORM CARD --- #}
                                <div class="card shadow-sm border-primary mb-4">
                                    <div class="card-header bg-primary text-white py-2 d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0"><i class="bi bi-pencil-square"></i> Redactar Nueva Evolución (SOAP)</h6>
                                        <span class="badge bg-light text-primary">{{ 'now'|date('d/m/Y H:i') }}</span>
                                    </div>
                                    <div class="card-body bg-light">
                                        {{ form_start(evolucionForm, {'action': path('app_hospitalizacion_nueva_evolucion', {'id': entity.id})}) }}

                                        <div class="row">
                                            <div class="col-md-4">
                                                {{ form_row(evolucionForm.condicionGeneral) }}
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group border-start border-4 border-info ps-3 mb-3">
                                                    {{ form_label(evolucionForm.subjetivo, null, {'label_attr': {'class': 'fw-bold text-info'}}) }}
                                                    {{ form_widget(evolucionForm.subjetivo) }}
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group border-start border-4 border-success ps-3 mb-3">
                                                    {{ form_label(evolucionForm.objetivo, null, {'label_attr': {'class': 'fw-bold text-success'}}) }}
                                                    {{ form_widget(evolucionForm.objetivo) }}
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group border-start border-4 border-warning ps-3 mb-3">
                                                    {{ form_label(evolucionForm.analisis, null, {'label_attr': {'class': 'fw-bold text-warning'}}) }}
                                                    {{ form_widget(evolucionForm.analisis) }}
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group border-start border-4 border-danger ps-3 mb-3">
                                                    {{ form_label(evolucionForm.plan, null, {'label_attr': {'class': 'fw-bold text-danger'}}) }}
                                                    {{ form_widget(evolucionForm.plan) }}
                                                </div>
                                            </div>
                                        </div>

                                        <div class="text-end mt-2">
                                            <button type="submit" class="btn btn-primary shadow-sm">
                                                <i class="bi bi-save"></i> Guardar y Firmar Evolución
                                            </button>
                                        </div>

                                        {{ form_end(evolucionForm) }}
                                    </div>
                                </div>
                                {# --- END FORM --- #}

                                {# --- THE HISTORY TIMELINE (Below the form) --- #}
                                <div class="timeline-container mt-5">
                                    <h6 class="text-muted fw-bold mb-3">Historial Clínico</h6>

                                    {% for evolucion in entity.evolucionHospitalarias|reverse %}
                                        <div class="card shadow-sm mb-3">
                                            <div class="card-header bg-white d-flex justify-content-between py-2">
                                                <strong><i class="bi bi-calendar2-week"></i> {{ evolucion.created|date('d/m/Y h:i A') }}</strong>
                                                <span class="badge {{ evolucion.condicionGeneral == 'Estable' ? 'bg-success' : 'bg-warning text-dark' }}">
                                        {{ evolucion.condicionGeneral.readableText }}
                                    </span>
                                            </div>
                                            <div class="card-body p-0">
                                                <table class="table table-bordered mb-0">
                                                    <tbody>
                                                    <tr>
                                                        <th class="bg-light" style="width: 15%">Subjetivo</th>
                                                        <td>{{ evolucion.subjetivo|nl2br }}</td>
                                                    </tr>
                                                    <tr>
                                                        <th class="bg-light">Objetivo</th>
                                                        <td>{{ evolucion.objetivo|nl2br }}</td>
                                                    </tr>
                                                    <tr>
                                                        <th class="bg-light">Análisis</th>
                                                        <td>{{ evolucion.analisis|nl2br }}</td>
                                                    </tr>
                                                    <tr>
                                                        <th class="bg-light">Plan</th>
                                                        <td>{{ evolucion.plan|nl2br }}</td>
                                                    </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                            <div class="card-footer bg-light text-end py-1">
                                                <small class="text-muted fst-italic">Firmado por: Dr(a). {{ evolucion.uidCreate|public_username }}</small>
                                            </div>
                                        </div>
                                    {% else %}
                                        <div class="alert alert-secondary text-center">
                                            Aún no hay evoluciones registradas para esta estancia hospitalaria.
                                        </div>
                                    {% endfor %}
                                </div>

                            </div> {# <-- THIS CLOSES THE EVOLUCIONES TAB PANE #}

                            {# TAB 2: KARDEX #}
                            <div class="tab-pane fade" id="kardex" role="tabpanel" aria-labelledby="kardex-tab" tabindex="0">
                                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
                                    <h5 class="fw-bold text-success"><i class="bi bi-card-checklist"></i> Órdenes Médicas (Kardex)</h5>
                                </div>

                                {# --- ONLY DOCTORS CAN PRESCRIBE --- #}
                                {% if is_granted('ROLE_DOCTOR') %}
                                    <div class="card shadow-sm border-success mb-4">
                                        <div class="card-header bg-success text-white py-2">
                                            <h6 class="mb-0"><i class="bi bi-plus-circle"></i> Agregar Nueva Indicación</h6>
                                        </div>
                                        <div class="card-body bg-light">
                                            {{ form_start(indicacionForm, {'action': path('app_hospitalizacion_nueva_indicacion', {'id': entity.id})}) }}
                                            <div class="row g-3 align-items-end">
                                                <div class="col-md-2">
                                                    {{ form_row(indicacionForm.tipo) }}
                                                </div>
                                                <div class="col-md-4">
                                                    {{ form_row(indicacionForm.descripcion) }}
                                                </div>
                                                <div class="col-md-2">
                                                    {{ form_row(indicacionForm.viaAdministracion) }}
                                                </div>
                                                <div class="col-md-2">
                                                    {{ form_row(indicacionForm.frecuencia) }}
                                                </div>
                                                <div class="col-md-2">
                                                    <button type="submit" class="btn btn-success w-100 shadow-sm">
                                                        <i class="bi bi-check2"></i> Prescribir
                                                    </button>
                                                </div>
                                            </div>
                                            {{ form_end(indicacionForm) }}
                                        </div>
                                    </div>
                                {% endif %}

                                {# --- THE ACTIVE ORDERS LIST (Visible to Doctors and Nurses) --- #}
                                <h6 class="text-muted fw-bold mb-3 mt-4">Indicaciones Activas</h6>

                                <div class="table-responsive">
                                    <table class="table table-hover align-middle border shadow-sm">
                                        <thead class="table-light">
                                        <tr>
                                            <th>Tipo</th>
                                            <th>Descripción de la Orden</th>
                                            <th>Vía</th>
                                            <th>Frecuencia</th>
                                            <th>Fecha/Médico</th>
                                            <th>Administrado</th>
                                            {% if is_granted('ROLE_DOCTOR') %}
                                                <th class="text-end">Acción</th>
                                            {% endif %}
                                        </tr>
                                        </thead>
                                        <tbody>
                                        {% for indicacion in entity.indicacionMedicas|filter(i => i.estado.value == 'active') %}
                                            <tr>
                                                <td>
                                                    <span class="badge {{ indicacion.tipo.value == 'medicine' ? 'bg-primary' : (indicacion.tipo.value == 'diet' ? 'bg-warning text-dark' : 'bg-secondary') }}">
                                                        {{ indicacion.tipo.readableText }}
                                                    </span>
                                                </td>
                                                <td class="fw-bold text-dark fs-5">{{ indicacion.descripcion }}</td>
                                                <td>{{ indicacion.viaAdministracion }}</td>
                                                <td><span class="badge bg-light text-dark border"><i class="bi bi-clock"></i> {{ indicacion.frecuencia }}</span></td>
                                                <td>
                                                    <small class="text-muted d-block">{{ indicacion.created|date('d/m/Y H:i') }}</small>
                                                    <small class="fst-italic">{{ indicacion.uidCreate|doctor_username }}</small>
                                                </td>
                                                {# --- THE NEW LAST DOSE COLUMN --- #}
                                                <td>
                                                    {% set ejecuciones = indicacion.kardexEnfermerias|filter(k => k.estado == 'Administrado')|sort((a, b) => b.created <=> a.created) %}
                                                    {% if ejecuciones|length > 0 %}
                                                        <span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> {{ ejecuciones|first.created|time_ago }}</span><br>
                                                        <small class="text-muted">{{ ejecuciones|first.created|date('d/m/Y H:i') }} (Lic. {{ ejecuciones|first.uidCreate|public_username }})</small>
                                                    {% else %}
                                                        <span class="text-warning fw-bold"><i class="bi bi-exclamation-circle"></i> Aún no administrado</span>
                                                    {% endif %}
                                                </td>

                                                {# --- ROLE SPECIFIC ACTIONS --- #}
                                                <td class="text-end">
                                                    <div class="d-flex justify-content-end gap-2">

                                                        {# NURSES: The Administration Button #}
                                                        {% if is_granted('ROLE_NURSE') %}
                                                            <form action="{{ path('app_hospitalizacion_administrar_indicacion', {'id': indicacion.id}) }}"
                                                                  method="POST"
                                                                  data-controller="confirm-finalizar"
                                                                  data-action="submit->confirm-finalizar#confirm"
                                                                  data-confirm-finalizar-title-value="¿Registrar Administración?"
                                                                  data-confirm-finalizar-text-value="¿Confirma que acaba de administrar '{{ indicacion.descripcion }}' al paciente?"
                                                                  data-confirm-finalizar-confirm-button-text-value="Sí, Registrar">

                                                                <input type="hidden" name="_token" value="{{ csrf_token('administer' ~ indicacion.id) }}">

                                                                <button type="submit" class="btn btn-success btn-sm" title="Marcar como Administrado">
                                                                    <i class="bi bi-check2-square"></i> Administrar
                                                                </button>
                                                            </form>
                                                        {% endif %}

                                                        {# DOCTORS: The Suspend Button (You already have this!) #}
                                                        {% if is_granted('ROLE_DOCTOR') %}
                                                            <form action="{{ path('app_hospitalizacion_suspender_indicacion', {'id': indicacion.id}) }}"
                                                                  method="POST"
                                                                  data-controller="confirm-finalizar"
                                                                  data-action="submit->confirm-finalizar#confirm"
                                                                  data-confirm-finalizar-title-value="¿Suspender Orden?"
                                                                  data-confirm-finalizar-text-value="¿Desea suspender permanentemente '{{ indicacion.descripcion }}'?"
                                                                  data-confirm-finalizar-confirm-button-text-value="Sí, Suspender">

                                                                <input type="hidden" name="_token" value="{{ csrf_token('suspend' ~ indicacion.id) }}">

                                                                <button type="submit" class="btn btn-outline-danger btn-sm" title="Suspender Orden">
                                                                    <i class="bi bi-x-octagon-fill"></i> Suspender
                                                                </button>
                                                            </form>
                                                        {% endif %}
                                                    </div>
                                                </td>
                                            </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="6" class="text-center text-muted py-4">No hay indicaciones activas para este paciente.</td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            {# TAB 3: VITALS #}
                            <div class="tab-pane fade" id="vitals" role="tabpanel" aria-labelledby="vitals-tab" tabindex="0">
                                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
                                    <h5 class="fw-bold text-danger"><i class="bi bi-heart-pulse"></i> Control de Signos Vitales</h5>
                                </div>

                                {# --- THE INPUT FORM --- #}
                                {% if is_granted('ROLE_NURSE') or is_granted('ROLE_DOCTOR') %}
                                    <div class="card shadow-sm border-danger mb-4">
                                        <div class="card-body bg-light">
                                            {{ form_start(vitalsForm, {'action': path('app_hospitalizacion_registrar_signos', {'id': entity.id})}) }}
                                            <div class="row g-2 align-items-end">
                                                <div class="col-md-2">
                                                    <label class="fw-bold text-muted small">PA Sistólica</label>
                                                    {{ form_widget(vitalsForm.paSistolica, {'attr': {'placeholder': '120'}}) }}
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="fw-bold text-muted small">PA Diastólica</label>
                                                    {{ form_widget(vitalsForm.paDiastolica, {'attr': {'placeholder': '80'}}) }}
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="fw-bold text-danger small">Frec. Cardíaca</label>
                                                    {{ form_widget(vitalsForm.frecuenciaCardiaca, {'attr': {'placeholder': 'LPM'}}) }}
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="fw-bold text-info small">Frec. Respiratoria</label>
                                                    {{ form_widget(vitalsForm.frecuenciaRespiratoria, {'attr': {'placeholder': 'RPM'}}) }}
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="fw-bold text-warning small">Temperatura (°C)</label>
                                                    {{ form_widget(vitalsForm.temperatura, {'attr': {'placeholder': '37.5'}}) }}
                                                </div>
                                                <div class="col-md-1">
                                                    <label class="fw-bold text-primary small">SpO2 (%)</label>
                                                    {{ form_widget(vitalsForm.spo2, {'attr': {'placeholder': '98'}}) }}
                                                </div>
                                                <div class="col-md-1">
                                                    <button type="submit" class="btn btn-danger w-100 shadow-sm" title="Guardar">
                                                        <i class="bi bi-plus-lg"></i>
                                                    </button>
                                                </div>
                                            </div>
                                            {{ form_end(vitalsForm) }}
                                        </div>
                                    </div>
                                {% endif %}

                                {# --- THE CHART CONTAINER --- #}
                                {% if entity.signosVitalesHospitalarios|length > 0 %}
                                    <div class="card shadow-sm mb-4">
                                        <div class="card-body">
                                            <h6 class="text-muted fw-bold mb-3">Gráfica de Tendencias (Temp & FC)</h6>
                                            <div style="position: relative; height: 300px;"
                                                 data-controller="vitals-chart"
                                                 data-vitals-chart-labels-value="{{ vitalsChartData.labels|json_encode }}"
                                                 data-vitals-chart-temp-value="{{ vitalsChartData.temp|json_encode }}"
                                                 data-vitals-chart-fc-value="{{ vitalsChartData.fc|json_encode }}">
                                                <canvas id="vitalsTrendChart"></canvas>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}

                                {# --- THE RAW DATA TABLE --- #}
                                <h6 class="text-muted fw-bold mb-3 mt-4">Historial de Registros</h6>
                                <div class="table-responsive">
                                    <table class="table table-hover table-sm align-middle border shadow-sm">
                                        <thead class="table-light">
                                        <tr>
                                            <th>Fecha y Hora</th>
                                            <th>Presión Arterial</th>
                                            <th>Frec. Cardíaca</th>
                                            <th>Frec. Resp.</th>
                                            <th>Temperatura</th>
                                            <th>SpO2</th>
                                            <th>Registrado por</th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        {# Sort descending so the newest is at the top of the table #}
                                        {% for vital in entity.signosVitalesHospitalarios|sort((a, b) => b.created <=> a.created) %}
                                            <tr>
                                                <td class="fw-bold">{{ vital.created|date('d/m/Y H:i') }}</td>
                                                <td>{{ vital.paSistolica ?: '--' }} / {{ vital.paDiastolica ?: '--' }}</td>
                                                <td>{{ vital.frecuenciaCardiaca ?: '--' }} <small class="text-muted">lpm</small></td>
                                                <td>{{ vital.frecuenciaRespiratoria ?: '--' }} <small class="text-muted">rpm</small></td>
                                                <td class="{{ vital.temperatura > 37.5 ? 'text-danger fw-bold' : '' }}">
                                                    {{ vital.temperatura ?: '--' }} <small class="text-muted">°C</small>
                                                </td>
                                                <td>{{ vital.spo2 ?: '--' }} <small class="text-muted">%</small></td>
                                                <td><small class="fst-italic">{{ vital.uidCreate|public_username }}</small></td>
                                            </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="7" class="text-center text-muted py-4">No hay registros de signos vitales.</td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# --- ALTA HOSPITALARIA MODAL --- #}
    {% if is_granted('ROLE_DOCTOR') %}
        <div class="modal fade" id="altaModal" tabindex="-1" aria-labelledby="altaModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content border-success">
                    <div class="modal-header bg-success text-white">
                        <h5 class="modal-title" id="altaModalLabel">
                            <i class="bi bi-box-arrow-right"></i> Procesar Alta Hospitalaria
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    {{ form_start(altaForm) }}
                    <div class="modal-body bg-light">
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle-fill"></i> <strong>Atención:</strong>
                            Esta acción finalizará la estancia del paciente y liberará la cama <strong>{{ entity.camaActual.codigo }}</strong> inmediatamente.
                        </div>

                        <div class="mb-3">
                            {{ form_row(altaForm.condicionAlta) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(altaForm.diagnosticoEgreso) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(altaForm.indicacionesAlta) }}
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-success shadow-sm" onclick="return confirm('¿Confirma que desea dar de alta a este paciente?');">
                            <i class="bi bi-check-circle-fill"></i> Confirmar Alta y Liberar Cama
                        </button>
                    </div>
                    {{ form_end(altaForm) }}
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
