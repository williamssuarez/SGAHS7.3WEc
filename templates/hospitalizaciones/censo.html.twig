{% extends 'base.html.twig' %}

{% block title %}Hospitalizaciones{% endblock %}

{% block titlewrap %}
    Hospitalizaciones
{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">Hospitalizaciones</li>
{% endblock %}

{% block body %}
    <div class="container-fluid px-4">
        <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
            <h2 class="text-dark fw-bold">
                <i class="bi bi-clipboard2-pulse"></i> Censo de Hospitalización
            </h2>
            <div>
                {# Optional: A quick summary badge #}
                <span class="badge bg-primary fs-6 rounded-pill shadow-sm">
                Áreas Activas: {{ groupedCenso|length }}
            </span>
            </div>
        </div>

        {% if groupedCenso is empty %}
            <div class="card shadow-sm border-0 bg-light p-5 text-center">
                <div class="text-muted">
                    <i class="bi bi-hospital display-1 mb-3"></i>
                    <h4>No hay pacientes hospitalizados actualmente</h4>
                </div>
            </div>
        {% else %}
            {# Loop through each Area (e.g., Pediatria, UCI, etc.) #}
            {% for areaName, pacientes in groupedCenso %}
                <div class="card shadow-sm mb-5 border-top border-info border-4">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h4 class="card-title mb-0 text-info fw-bold">
                            <i class="bi bi-geo-alt-fill"></i> {{ areaName }}
                        </h4>
                        <span class="badge bg-secondary rounded-pill">{{ pacientes|length }} Pacientes</span>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                <tr>
                                    <th style="width: 15%">Ubicación</th>
                                    <th style="width: 25%">Paciente</th>
                                    <th style="width: 20%">Diagnóstico de Ingreso</th>
                                    <th style="width: 15%">Días Ingresado</th>
                                    <th style="width: 15%">Médico Tratante</th>
                                    <th style="width: 10%" class="text-end">Acciones</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for hospitalizacion in pacientes %}
                                    <tr>
                                        <td>
                                            <span class="fw-bold fs-5 text-dark">
                                                {{ hospitalizacion.camaActual.habitacion.nombre }}
                                            </span><br>
                                            <span class="badge bg-dark">Cama: {{ hospitalizacion.camaActual.codigo }}</span>
                                        </td>
                                        <td>
                                            <strong>{{ hospitalizacion.paciente.nombre }} {{ hospitalizacion.paciente.apellido }}</strong><br>
                                            <small class="text-muted">CI: {{ hospitalizacion.paciente.cedula }}</small>
                                        </td>
                                        <td>
                                            <div class="text-truncate" style="max-width: 200px;" title="{{ hospitalizacion.diagnosticoIngreso }}">
                                                {{ hospitalizacion.diagnosticoIngreso }}
                                            </div>
                                        </td>
                                        <td>
                                            {# Calculate days since admission #}
                                            {% set dias = date('now').diff(hospitalizacion.fechaIngreso).days %}
                                            {% if dias == 0 %}
                                                <span class="badge bg-success">Hoy</span>
                                            {% elseif dias > 14 %}
                                                <span class="badge bg-danger">{{ dias }} Días (Larga Estancia)</span>
                                            {% else %}
                                                <span class="badge bg-warning text-dark">{{ dias }} Días</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if hospitalizacion.medicoTratante %}
                                                Dr(a). {{ hospitalizacion.medicoTratante.usuario.nombre }}
                                            {% else %}
                                                <span class="text-danger small"><i class="bi bi-exclamation-triangle"></i> Sin Asignar</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end">
                                            {# This will link to the massive Inpatient Record view we build next #}
                                            {% if is_granted('ROLE_DOCTOR') or is_granted('ROLE_NURSE') %}
                                                <a href="{{ path('app_hospitalizacion_expediente', {'id': hospitalizacion.id}) }}" class="btn btn-outline-primary btn-sm shadow-sm">
                                                    <i class="bi bi-folder2-open"></i> Expediente
                                                </a>
                                            {% endif %}
                                            {% if is_granted('ROLE_RECEPTIONIST') %}
                                                <a href="{{ path('app_visitas_registrar', {'id': hospitalizacion.id}) }}" class="btn btn-outline-primary btn-sm shadow-sm">
                                                    <i class="bi bi-person-plus-fill"></i> Registrar Nuevo Visitante
                                                </a>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
{% endblock %}
